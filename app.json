{
  "expo": {
    "name": "OneScan",
    "slug": "OneScan",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "onescan",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      ["./plugins/withGradleWrapper", { "gradleVersion": "8.10.2" }],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "OneScan benötigt Kamerazugriff für QR-Code-Scan und Dokumentaufnahme."
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class expo.modules.smbwriter.** { *; }\n-keep class expo.modules.documentdetector.** { *; }"
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neuhauser.onescan",
      "infoPlist": {
        "NSCameraUsageDescription": "OneScan benötigt Kamerazugriff für QR-Code-Scan und Dokumentaufnahme."
      }
    },
    "android": {
      "package": "com.neuhauser.onescan",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aadf96f0-262f-48e0-9a73-3510525c1727"
      }
    },
    "owner": "marion808"
  }
}
